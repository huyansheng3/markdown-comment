{
  "name": "comment-md-remark-plugin",
  "version": "0.1.1",
  "description": "Remark plugin for comment-md annotations - human-AI collaborative commenting",
  "homepage": "https://github.com/huyansheng3/markdown-comment#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huyansheng3/markdown-comment.git",
    "directory": "packages/packages/remark-plugin"
  },
  "bugs": {
    "url": "https://github.com/huyansheng3/markdown-comment/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "unified": ">=10.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.3",
    "@types/unist": "^3.0.2",
    "mdast-util-from-markdown": "^2.0.0",
    "remark-parse": "^11.0.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "unified": "^11.0.4",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "remark",
    "remark-plugin",
    "markdown",
    "comment",
    "annotation"
  ],
  "author": "huyansheng",
  "license": "MIT",
  "sideEffects": false
}
